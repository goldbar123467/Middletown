{
  "name": "middletown",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A browser-based local government strategy game about running a mid-sized Midwestern town.",
  "repository": {
    "type": "git",
    "url": "https://github.com/goldbar123467/Middletown.git"
  },
  "homepage": "https://github.com/goldbar123467/Middletown#readme",
  "bugs": {
    "url": "https://github.com/goldbar123467/Middletown/issues"
  },
  "keywords": [
    "browser-game",
    "local-government",
    "civic-sim",
    "strategy-game",
    "react",
    "vite",
    "playwright",
    "reducer-state-machine",
    "rl-playtest",
    "municipal-budget"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node tests/run-tests.mjs",
    "test:browser": "node tests/playwright/uiSmoke.mjs && node tests/playwright/endStateSmoke.mjs",
    "playtest:rl": "node tests/playwright/runMiddletownRlPlaytest.mjs",
    "playtest:rl:matrix": "node tests/playwright/runRlMatrix.mjs",
    "qa": "npm run lint && npm run test && npm run build",
    "lines": "node tools/count-lines.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.3.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "lucide-react": "^0.577.0",
    "tailwindcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.56.1"
  }
}
